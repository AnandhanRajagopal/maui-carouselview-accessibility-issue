<?xml version="1.0" encoding="utf-8" ?>
<!--
    StepDataTemplate — per-item layout for the CarouselView.
    Bound to Models.StepData (x:DataType enforces compile-time binding).
    Mirrors StepDataTemplate.xaml from XCApp.Easyfit — simplified to
    show Heading, Image and Description without custom controls.
-->
<ContentView
    x:Class="SampleCarousel.Controls.StepDataTemplate"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:SampleCarousel.Models"
    x:DataType="model:StepData">

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="16,20"
          RowSpacing="16">

        <!-- Step heading -->
        <Label
            Grid.Row="0"
            AutomationId="TA_Carousel_View_Heading"
            Text="{Binding StepHeading}"
            FontSize="20"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            VerticalOptions="Center"/>

        <!-- Step illustration -->
        <Image
            Grid.Row="1"
            Source="dotnet_bot.png"
            HeightRequest="180"
            Aspect="AspectFit"
            HorizontalOptions="Center"/>

        <!-- Description / body text -->
        <ScrollView
            Grid.Row="2"
            VerticalScrollBarVisibility="Never">
            <Label
                Text="{Binding Description}"
                FontSize="14"
                HorizontalTextAlignment="Center"
                VerticalOptions="Start"/>
        </ScrollView>

    </Grid>
</ContentView>
